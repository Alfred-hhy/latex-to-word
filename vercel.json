{
  "rewrites": [
    { "source": "/api/preview", "destination": "/api/preview.js" },
    { "source": "/api/convert", "destination": "/api/convert.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}